---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const canonical = 'https://earlyleaseterminationcalculator.com/articles/';
---
<BaseLayout
  title="Lease Break Guides & Advice — LeaseAdvisor"
  description="Practical articles on how to break a lease, understand your state's laws, and minimize what you owe."
  canonical={canonical}
>
  <div class="main--wide">
    <div style="margin-bottom: 32px;">
      <p class="eyebrow">Lease Advisor Guides</p>
      <h1 class="title" style="font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 400; line-height: 1.25; color: var(--ink); margin-bottom: 8px;">Articles & Advice</h1>
      <p class="subtitle">Practical guidance on breaking a lease, understanding your rights, and reducing what you owe.</p>
    </div>
    <div class="article-grid">
      {articles.map(article => (
        <a href={`/articles/${article.id}`} class="article-card-item">
          <div class="article-card-title">{article.data.title}</div>
          <div class="article-card-desc">{article.data.description}</div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
