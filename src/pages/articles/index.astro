---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

function getBadge(article: any): { label: string; type: 'state' | 'strategy' | 'guide' } {
  if (article.data.state) return { label: 'State Guide', type: 'state' };
  const slug = article.id ?? '';
  if (slug.includes('how-to') || slug.includes('-vs-')) return { label: 'Strategy', type: 'strategy' };
  return { label: 'Guide', type: 'guide' };
}

const TYPE_ORDER: Record<string, number> = { strategy: 0, guide: 1, state: 2 };

const articles = (await getCollection('articles')).sort((a, b) => {
  const typeA = TYPE_ORDER[getBadge(a).type] ?? 99;
  const typeB = TYPE_ORDER[getBadge(b).type] ?? 99;
  if (typeA !== typeB) return typeA - typeB;
  return b.data.publishDate.getTime() - a.data.publishDate.getTime();
});

function formatDate(d: Date) {
  // Use UTC to avoid timezone shifting the date stored in frontmatter
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
}

const canonical = 'https://earlyleaseterminationcalculator.com/articles';
---
<BaseLayout
  title="Lease Break Guides & Advice — LeaseAdvisor"
  description="Practical articles on how to break a lease, understand your state's laws, and minimize what you owe."
  canonical={canonical}
>
  <div class="main--wide">
    <div class="articles-header">
      <div>
        <p class="eyebrow">Lease Advisor Guides</p>
        <h1 class="articles-heading">Articles & Advice</h1>
        <p class="articles-subheading">Practical guidance on breaking a lease, understanding your rights, and reducing what you owe.</p>
      </div>
    </div>
    <div class="article-grid">
      {articles.map(article => {
        const badge = getBadge(article);
        return (
          <a href={`/articles/${article.id}`} class={`article-card-item article-card--${badge.type}`}>
            <div class="article-card-header">
              <span class={`article-card-badge article-card-badge--${badge.type}`}>{badge.label}</span>
              <span class="article-card-date">{formatDate(article.data.publishDate)}</span>
            </div>
            <div class="article-card-title">{article.data.title}</div>
            <div class="article-card-desc">{article.data.description}</div>
            <div class="article-card-cta">Read <span aria-hidden="true">→</span></div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
