---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

function getType(entry: any): 'state' | 'strategy' | 'guide' {
  if (entry.data.state) return 'state';
  const slug = entry.id ?? '';
  if (slug.includes('how-to') || slug.includes('-vs-')) return 'strategy';
  return 'guide';
}

const articleType = getType(entry);
const canonical = `https://earlyleaseterminationcalculator.com/articles/${entry.id}`;

const words = entry.body.trim().split(/\s+/).length;
const readTime = `${Math.max(1, Math.round(words / 200))} min read`;
---
<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical={canonical}
  publishDate={entry.data.publishDate}
  type={articleType}
  readTime={readTime}
>
  <Content />
</ArticleLayout>
