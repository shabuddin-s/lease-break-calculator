---
import BaseLayout from '../layouts/BaseLayout.astro';
import Calculator from '../components/Calculator.astro';

const title = 'Lease Break Penalty Calculator — What You\'ll Actually Owe';
const description = 'Calculate your early lease termination penalty by state. See best case, most likely, and worst case estimates based on your state\'s actual landlord-tenant laws. Free, no signup.';
const canonical = 'https://earlyleaseterminationcalculator.com/';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Lease Break Penalty Calculator",
    "description": "Calculate your early lease termination penalty based on state-specific landlord-tenant laws.",
    "url": canonical,
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "All",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much do I owe for breaking my lease?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It depends on your state and how quickly your landlord re-rents the unit. In most states, landlords are legally required to find a new tenant and you only owe rent until they do. Use this calculator to get a state-specific estimate."
        }
      },
      {
        "@type": "Question",
        "name": "Do I have to pay all remaining rent if I break my lease?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In most US states, no. Most states require landlords to 'mitigate damages' by actively trying to re-rent the unit. You only owe rent for the time the unit sits vacant, not necessarily all remaining months. States like Alabama, Arkansas, Louisiana, Mississippi, West Virginia, and Wyoming are exceptions — they have no mitigation requirement."
        }
      },
      {
        "@type": "Question",
        "name": "What is the penalty for breaking a lease early?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The penalty varies by state and lease terms. It may be a flat early termination fee written into your lease, or it may equal rent owed until a new tenant is found. Delaware and Maryland cap penalties at 2 months' rent; Oregon caps them at 1.5 months' rent."
        }
      }
    ]
  }
];
---
<BaseLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <div class="main">
    <Calculator />
  </div>
</BaseLayout>
