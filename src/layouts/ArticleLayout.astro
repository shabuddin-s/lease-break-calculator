---
import BaseLayout from './BaseLayout.astro';
import ArticleIcon from '../components/ArticleIcon.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  publishDate?: Date;
  type?: 'state' | 'strategy' | 'guide';
  readTime?: string;
}

const { title, description, canonical, publishDate, type, readTime } = Astro.props;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "url": canonical,
  "datePublished": publishDate?.toISOString(),
  "dateModified": publishDate?.toISOString(),
  "image": "https://earlyleaseterminationcalculator.com/og-image.png",
  "author": {
    "@type": "Organization",
    "name": "LeaseAdvisor",
    "url": "https://earlyleaseterminationcalculator.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "LeaseAdvisor",
    "url": "https://earlyleaseterminationcalculator.com"
  }
};
---
<BaseLayout title={title} description={description} canonical={canonical} jsonLd={articleSchema} ogType="article">
  <div class="main">
    <article class="article-card" data-pagefind-body>
      <div class="article-header-row">
        {type && (
          <div class={`article-icon-wrap article-icon-wrap--${type}`}>
            <ArticleIcon type={type} size={32} />
          </div>
        )}
        <div class="article-header-meta">
          {publishDate && (
            <span class="article-date">
              {publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}
            </span>
          )}
          {readTime && <span class="article-read-time">{readTime}</span>}
        </div>
      </div>
      <p class="article-disclaimer">This article is for informational purposes only — not legal advice. For your specific situation, consider speaking with a tenant rights attorney or local legal aid office.</p>
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .article-card {
    background: white;
    border-radius: 16px;
    padding: 40px 48px;
    max-width: 720px;
    margin: 0 auto;
    box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.04);
    line-height: 1.75;
  }

  .article-header-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .article-header-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    gap: 2px;
  }

  .article-date {
    display: block;
    font-size: 13px;
    color: var(--ink-muted);
  }

  .article-read-time {
    display: block;
    font-size: 12px;
    color: var(--ink-faint);
  }

  .article-disclaimer {
    font-size: 13px;
    color: var(--ink-muted);
    font-style: italic;
    border-left: 3px solid var(--border, #e5e7eb);
    padding-left: 12px;
    margin-bottom: 32px;
  }

  .article-card :global(h1) {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    line-height: 1.2;
    margin-bottom: 16px;
    color: var(--ink);
  }

  .article-card :global(h2) {
    font-size: 1.35rem;
    font-weight: 700;
    margin-top: 48px;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border, #e5e7eb);
    color: var(--ink);
  }

  .article-card :global(h3) {
    font-size: 1.05rem;
    font-weight: 600;
    margin-top: 28px;
    margin-bottom: 8px;
    color: var(--ink);
  }

  .article-card :global(p) {
    color: var(--ink-light);
    margin-bottom: 16px;
  }

  .article-card :global(ul), .article-card :global(ol) {
    padding-left: 24px;
    color: var(--ink-light);
    margin-bottom: 16px;
  }

  .article-card :global(li) {
    margin-bottom: 8px;
  }

  .article-card :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin-bottom: 24px;
  }

  .article-card :global(th) {
    text-align: left;
    font-weight: 600;
    color: var(--ink);
    padding: 10px 14px;
    border-bottom: 2px solid var(--border, #e5e7eb);
  }

  .article-card :global(td) {
    padding: 10px 14px;
    color: var(--ink-light);
    border-bottom: 1px solid var(--border, #e5e7eb);
  }

  .article-card :global(tr:last-child td) {
    border-bottom: none;
  }

  .article-card :global(tr:nth-child(even) td) {
    background: #f9fafb;
  }

  @media (max-width: 600px) {
    .article-card {
      padding: 24px 20px;
    }
  }
</style>
